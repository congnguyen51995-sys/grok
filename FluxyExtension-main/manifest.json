{
  "manifest_version": 3,
  "name": "Fluxy Extension - Thành Công Media",
  "version": "2.3",
  "description": "Kết nối Veo Studio với Fluxy Tool",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "cookies",
    "webRequest",
    "downloads",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://labs.google/*"],
      "js": ["content_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://labs.google/*"],
      "js": ["content_iso.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "Fluxy Extension Status"
  }
}
